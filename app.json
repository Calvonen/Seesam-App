{
  "expo": {
    "name": "Seesam",
    "slug": "seesam-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "seesam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.seesam.app",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "lanApiBaseUrl": "http://192.168.68.74:8000",
      "publicApiBaseUrl": "http://100.95.239.27:8000",
      "tailscaleApiBaseUrl": "http://100.95.239.27:8000",
      "router": {},
      "eas": {
        "projectId": "5f65bd30-ad48-45b9-b8b9-c808df65f72c"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Seesam tarvitsee mikrofonia push-to-talk-kysymyksiin."
      }
    }
  }
}
