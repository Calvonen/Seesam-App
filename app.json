    "android": {
      "package": "com.seesam.app",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "lanApiBaseUrl": "http://192.168.68.74:8000",
      "publicApiBaseUrl": "http://100.90.126.101:8000",
      "tailscaleApiBaseUrl": "http://100.90.126.101:8000"
    },
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Seesam tarvitsee mikrofonia push-to-talk-kysymyksiin."
      }
    }
  }
}
